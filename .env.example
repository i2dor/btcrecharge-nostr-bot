# Bot identity. Generate ONCE in production and persist offline.
# Loss of NSEC = loss of bot identity (no recovery).
BOT_NSEC=

# Btcrecharge proxy auth. Must match NOSTR_PROXY_SECRET in btcrecharge .env.
# 64-hex characters (HMAC-SHA256 strength). Rotate every 90 days.
NOSTR_PROXY_SECRET=

# Btcrecharge backend base URL (no trailing slash).
BTCRECHARGE_BASE_URL=https://btcrecharge.com

# Relay list. Comma-separated wss:// URLs.
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.snort.social

# Redis. Railway auto-injects this.
REDIS_URL=redis://localhost:6379

# HTTP server (webhook receiver).
PORT=3000

# Logging. trace | debug | info | warn | error
LOG_LEVEL=info

# Environment marker. Affects telemetry tags and test-mode gates.
APP_ENV=development

# Public origin btcrecharge POSTs order callbacks to. REQUIRED in production.
# Set this once you have generated a public domain for the Railway service:
#   Railway Dashboard -> Service -> Settings -> Networking -> Generate Domain
# Take the resulting host (e.g. btcrecharge-nostr-bot.up.railway.app) and put
# the full origin here:
#   BOT_PUBLIC_URL=https://btcrecharge-nostr-bot.up.railway.app
# If left empty AND RAILWAY_PUBLIC_DOMAIN is not injected, the bot falls back
# to http://localhost:PORT which btcrecharge cannot reach - delivery DMs go
# missing silently (see Phase 2.7 post-mortem for orders #1015-#1017).
BOT_PUBLIC_URL=

# Hide PIN-delivery operators (default true). Set to `false` once a secure
# voucher PIN delivery flow on Nostr ships - PIN ops require the customer
# to manually redeem a code, and stuck orders on Nostr have no email
# fallback. See Phase 3 refund flow task.
DIRECT_TOPUP_ONLY=true
